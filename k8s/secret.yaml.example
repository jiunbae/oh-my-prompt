# Example secret file - DO NOT COMMIT with real values
# Create actual secret with: kubectl apply -f secret.yaml
# Or use sealed-secrets for GitOps
apiVersion: v1
kind: Secret
metadata:
  name: oh-my-prompt-secrets
  namespace: oh-my-prompt
type: Opaque
stringData:
  DATABASE_URL: "postgresql://prompt:your-db-password@prompt-db-service:5432/prompts"
  POSTGRES_PASSWORD: "your-db-password"
  SESSION_SECRET: "your-session-secret-here"
  SYNC_TOKEN: "your-sync-token-here"
  # LLM (Azure OpenAI)
  OMP_LLM_PROVIDER: "azure"
  OMP_LLM_API_KEY: "your-azure-openai-api-key"
  OMP_LLM_BASE_URL: "https://your-resource.cognitiveservices.azure.com"
  OMP_LLM_AZURE_DEPLOYMENT: "your-deployment-name"
  OMP_LLM_MODEL: "gpt-4o-mini"
